#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>

// Function Implementation

void sparse_multiply(
    int rows, int cols,
    const double* A,
    const double* x,
    int* out_nnz,
    double* values,
    int* col_indices,
    int* row_ptrs,
    double* y
) {
    int nnz = 0;

    // CSR row pointer start
    row_ptrs[0] = 0;

  //The following section converts the matrix into the CSR format 

    for (int i = 0; i < rows; i++) {

        for (int j = 0; j < cols; j++) {

            double val = A[i * cols + j]; // Iam using double instead of float for better precision 

            if (val != 0.0) {
                values[nnz] = val;
                col_indices[nnz] = j;
                nnz++;
            }
        }

        row_ptrs[i + 1] = nnz;
    }

    *out_nnz = nnz;

   // This section covers the actual multiplication between the vector and the CSR

    for (int i = 0; i < rows; i++) {

        y[i] = 0.0;

        for (int k = row_ptrs[i]; k < row_ptrs[i + 1]; k++) {
            y[i] += values[k] * x[col_indices[k]];
        }
    }
}

// Test Harness 


int main(void) {
    srand(time(NULL));

    const int num_iterations = 10;
    int passed_count = 0;

    for (int iter = 0; iter < num_iterations; ++iter) {

        int rows = rand() % 10 + 3;
        int cols = rand() % 10 + 3;
        double density = 0.2;

        size_t mat_sz = (size_t) rows * cols;

        double* A = calloc(mat_sz, sizeof(double));

        for (size_t i = 0; i < mat_sz; ++i) {
            if (((double) rand() / RAND_MAX) < density) {
                A[i] = ((double) rand() / RAND_MAX) * 10.0;
            }
        }

        double* values = malloc(mat_sz * sizeof(double));
        int* col_indices = malloc(mat_sz * sizeof(int));
        int* row_ptrs = malloc((rows + 1) * sizeof(int));

        double* x = malloc(cols * sizeof(double));
        double* y_user = malloc(rows * sizeof(double));
        double* y_ref = calloc(rows, sizeof(double));

        int out_nnz = 0;

        for (int i = 0; i < cols; i++) {
            x[i] = ((double) rand() / RAND_MAX) * 10.0;
        }

        // Reference
        for (int i = 0; i < rows; i++) {
            double sum = 0.0;
            for (int j = 0; j < cols; j++) {
                sum += A[i * cols + j] * x[j];
            }
            y_ref[i] = sum;
        }

        sparse_multiply(rows, cols, A, x,
                         &out_nnz,
                         values, col_indices, row_ptrs,
                         y_user);

        // Check
        int pass = 1;
        for (int i = 0; i < rows; i++) {
            if (fabs(y_user[i] - y_ref[i]) > 1e-7) {
                pass = 0;
            }
        }

        printf("Test %d: %s (nnz=%d)\n", iter, pass ? "PASS" : "FAIL", out_nnz);

        if (pass) passed_count++;

        free(A);
        free(values);
        free(col_indices);
        free(row_ptrs);
        free(x);
        free(y_user);
        free(y_ref);
    }

    printf("\nResult: %d/%d passed\n", passed_count, num_iterations);

    return 0;
}
